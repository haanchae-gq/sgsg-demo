# ============================================
# SGSG (쓱싹 홈케어 플랫폼) - 환경 변수
# ============================================

# 데이터베이스 연결
DB_URL="postgresql://myuser:mypass@localhost:5432/mydb"

# JWT 설정
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# 애플리케이션 설정
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3000"
MOBILE_URL="http://localhost:3002"

# CORS 설정
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# 파일 업로드
MAX_FILE_SIZE="10mb"
UPLOAD_DIR="./uploads"

# 로깅
LOG_LEVEL="info"

# 이메일 설정 (선택 사항)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@sgsg.com"

# 결제 게이트웨이 (선택 사항)
PG_PROVIDER="toss_payments"
PG_API_KEY="your-pg-api-key"
PG_SECRET_KEY="your-pg-secret-key"

# 외부 API (선택 사항)
MAPS_API_KEY="your-google-maps-api-key"
SMS_API_KEY="your-sms-api-key"

# ============================================
# 개발용 기본값
# ============================================

# 개발용 관리자 계정
ADMIN_EMAIL="admin@sgsg.com"
ADMIN_PASSWORD="admin123"
ADMIN_PHONE="01012345678"

# 개발용 전문가 계정
EXPERT_EMAIL="expert@sgsg.com"
EXPERT_PASSWORD="expert123"
EXPERT_PHONE="01087654321"

# 개발용 고객 계정
CUSTOMER_EMAIL="customer@sgsg.com"
CUSTOMER_PASSWORD="customer123"
CUSTOMER_PHONE="01011112222"