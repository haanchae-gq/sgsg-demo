DB_URL="postgresql://myuser:mypass@localhost:5432/mydb"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="your-secret-key-change-this"

# Email SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@yourdomain.com"

# Frontend URLs
FRONTEND_URL="http://localhost:3001"
MOBILE_FRONTEND_URL="http://localhost:3002"

# File Upload
UPLOAD_DIR="./uploads"
FILE_BASE_URL="http://localhost:4000/uploads"

# Payment Gateway (헥토 파이낸셜)
PG_PROVIDER="hecto"
HECTO_ENV="development"
HECTO_MID="your-merchant-id"
HECTO_API_KEY="your-api-key"
HECTO_SECRET_KEY="your-secret-key"
HECTO_API_URL="https://dev-api.hecto.co.kr"